{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "clusterId": { "type": "string" },
        "lokiEnabled": { "type": "boolean" },
        "lokiUrl": { "type": "string" },
        "lokiLookbackMinutes": { "type": "integer", "minimum": 1 },
        "lokiMaxLogLines": { "type": "integer", "minimum": 1 },
        "prometheusUrl": { "type": "string" },
        "prometheusLookbackMinutes": { "type": "integer", "minimum": 1 },
        "prometheusEnabled": { "type": "boolean" },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "redactLogStats": { "type": "boolean" },
        "redactExtraPatterns": { "type": "string" }
      },
      "required": ["clusterId"]
    },
    "externalSecrets": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "secretStoreName": { "type": "string" },
        "secretStoreKind": { "type": "string" },
        "remoteSecretPath": { "type": "string" },
        "refreshInterval": { "type": "string" }
      }
    },
    "devSecrets": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "centralAgentUrl": { "type": "string" },
        "centralAgentToken": { "type": "string" }
      }
    },
    "resources": { "type": "object" }
  }
}
